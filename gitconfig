[user]
  name = Gabriel Rinaldi
  email = gabriel_rinaldi@mac.com
[push]
  default = simple
[core]
  editor = subl
  excludesfile = /Users/Gabriel/.gitignore
  trustctime = false
[color]
    ui = auto
  [color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
  [color "diff"]
    old = red
    new = green
  [color "status"]
    added = yellow
    changed = green
    untracked = cyan
[mergetool]
  keepBackup = true
  prompt = false
[difftool "Kaleidoscope"]
  cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"
[diff]
  tool = Kaleidoscope
[difftool]
  prompt = false
[mergetool "Kaleidoscope"]
  cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
  trustExitCode = true
[merge]
  tool = Kaleidoscope

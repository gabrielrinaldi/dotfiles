[user]
	name = Gabriel Rinaldi
	email = gabriel_rinaldi@mac.com
	signingkey = EE093ABF773273C67106981FB5C1801B917EA40C

[push]
	default = simple

[core]
	editor = nvim
	excludesfile = /Users/gabriel/.gitignore
	trustctime = false

[color]
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	commit = yellow reverse
	old = red
	new = green

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[credential]
	helper = osxkeychain

[merge "Kaleidoscope"]
	log = true
	conflictstyle = diff3
	tool = Kaleidoscope

[mergetool]
	keepBackup = true
	prompt = true

[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true

[diff]
	tool = Kaleidoscope

[difftool]
	prompt = false

[difftool "Kaleidoscope"]
  cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	required = true
	process = git-lfs filter-process

[alias]
	lol = log --graph --decorate --oneline

[pull]
	rebase = true

[commit]
	gpgsign = true

[gpg]
	program = /usr/local/bin/gpg

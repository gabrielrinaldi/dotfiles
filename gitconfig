[user]
	name = Gabriel Rinaldi
	email = gabriel_rinaldi@mac.com

[push]
	default = simple

[core]
	editor = subl
	excludesfile = /Users/Gabriel/.gitignore
	trustctime = false

[color]
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	commit = yellow reverse
	old = red
	new = green

[color "status"]
	added = yellow
	changed = green
	untracked = cyan

[merge "Kaleidoscope"]
	log = true
	conflictstyle = diff3
	tool = Kaleidoscope

[merge "mergepbx"]
  name = Xcode project files merger
  driver = mergepbx %O %A %B

[mergetool]
	keepBackup = true
	prompt = true

[mergetool "Kaleidoscope"]
	cmd = ksdiff --merge --output \"$MERGED\" --base \"$BASE\" -- \"$LOCAL\" --snapshot \"$REMOTE\" --snapshot
	trustExitCode = true

[mergetool "mergepbx"]
  cmd = mergepbx "$BASE" "$LOCAL" "$REMOTE" -o "$MERGED"

[diff]
	tool = Kaleidoscope

[difftool]
	prompt = false

[difftool "Kaleidoscope"]
  cmd = ksdiff --partial-changeset --relative-path \"$MERGED\" -- \"$LOCAL\" \"$REMOTE\"

[filter "lfs"]
	clean = git-lfs clean %f
	smudge = git-lfs smudge %f
	required = true

[http]
	cookiefile = /Users/Gabriel/.gitcookies

[alias]
	lol = log --graph --decorate --oneline
